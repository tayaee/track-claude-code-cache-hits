{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run CLI: claude_code_cache",
            "type": "debugpy",
            "request": "launch",
            "module": "claude_code_cache.cli",
            "console": "integratedTerminal",
            "preLaunchTask": "uv-sync"
        },
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "preLaunchTask": "uv-sync"
        }
    ]
}